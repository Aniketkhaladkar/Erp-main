# Copy this file to .env and fill in values from your Supabase project.
# Get these at: https://supabase.com/dashboard/project/_/settings/api
#
# VITE_* vars are inlined into the client bundle by Vite at build time,
# so only use publishable (anon) keys here — never service role keys.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Server-only mirrors (used by any server code that runs outside the browser)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
